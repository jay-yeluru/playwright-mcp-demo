{
  "compilerOptions": {
    "target": "ESNext",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "tests/**/*",
    "pages/**/*",
    "fixtures/**/*",
    "data/**/*"
  ],
  "exclude": [
    "node_modules",
    "playwright.config.ts"
  ]
}